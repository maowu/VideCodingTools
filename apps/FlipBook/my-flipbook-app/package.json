{
  "name": "pdf-flipbook-app",
  "version": "1.0.0",
  "description": "3D PDF Flipbook Viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.flipbook.viewer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable" 
    }
  }
}